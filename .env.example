# Postgres (Neon): use pooled URL for the app; optional direct URL for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: Svix signing secret for `POST /api/webhooks/clerk`
CLERK_WEBHOOK_SECRET=

# Optional: default org id for webhook-created users (matches seeded Mealize org)
DEFAULT_ORGANIZATION_ID=1

# Optional: your Clerk user id (e.g. user_2abc...) so seed user id=1 matches your login after `npm run db:seed`.
# Then Messages shows demo threads with Manager 2 and Manager 3.
# MEALIZE_DEV_CLERK_ID=

# AWS S3 presigned uploads (server only)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Browser uploads (PUT) require CORS on the bucket, e.g. AllowedOrigins: your dev/prod app URL, AllowedMethods: PUT, AllowedHeaders: *.

# When unset/false, legacy demo URLs (mealizeaa.s3.amazonaws.com) are rewritten to Picsum placeholders in API + seed.
# Set to true once your real bucket/CDN URLs are in the database.
# DISABLE_LEGACY_MEDIA_PLACEHOLDER=true
